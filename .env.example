# MediQaz — переменные окружения
# Скопируйте этот файл: cp .env.example .env
# Заполните значения своими ключами

# Deepgram — распознавание речи (STT)
# Получить: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_key_here

# Groq — LLM для генерации медицинских форм
# Получить: https://console.groq.com/
GROQ_API_KEY=your_groq_key_here

# JWT — секрет для токенов авторизации
# Сгенерировать: openssl rand -base64 32
JWT_SECRET=generate_a_strong_secret_here

# Порт сервера (по умолчанию 3000)
PORT=3000

# Путь к базе данных SQLite
DB_PATH=./mediqaz.db
