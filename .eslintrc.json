{
  "env": { "node": true, "browser": true, "es2022": true },
  "extends": ["eslint:recommended", "prettier"],
  "parserOptions": { "ecmaVersion": 2022 },
  "rules": {
    "no-unused-vars": "warn",
    "require-await": "warn",
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["warn", "single", { "avoidEscape": true }]
  },
  "ignorePatterns": ["node_modules/", "public/sw.js"]
}
